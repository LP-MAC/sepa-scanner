"""
Relative Strength (RS) Rating: percentile rank of 12-month total return vs universe.
Minervini's methodology: strict 12-month requirement. Tickers without 12 months
of data are excluded to avoid inflating RS for new IPOs with shorter histories.
"""
import logging

import numpy as np
import pandas as pd
from scipy import stats

logger = logging.getLogger(__name__)


def compute_rs_ratings(
    data: dict[str, pd.DataFrame],
    lookback_months: int = 12,
) -> dict[str, float]:
    """Compute RS rating (0-100) for each ticker based on 12-month total return.
    
    Strict requirement: tickers must have at least 12 months (~252 trading days)
    of data. Tickers with shorter histories (e.g. recent IPOs) are excluded
    from the percentile calculation to avoid comparing 6-month returns against
    12-month returns, which would inflate RS for newer stocks.
    """
    if not data:
        return {}

    required_days = lookback_months * 20  # ~252 trading days for 12 months

    returns: dict[str, float] = {}

    for ticker, df in data.items():
        available_days = len(df)
        if available_days < required_days:
            logger.debug(f"{ticker}: insufficient history for RS ({available_days} < {required_days} days)")
            continue
        
        try:
            start_close = df["close"].iloc[-required_days]
            end_close = df["close"].iloc[-1]
            if start_close > 0 and end_close > 0:
                total_return = (end_close / start_close) - 1.0
                returns[ticker] = total_return
        except (IndexError, KeyError, ZeroDivisionError):
            continue

    if not returns:
        logger.warning("No valid returns computed for RS rating — all tickers may have insufficient history")
        return {}

    return_array = np.array(list(returns.values()))
    ratings = {}

    for ticker, ret in returns.items():
        # Use kind="mean" for percentile to match IBD-style ranking more closely
        percentile = stats.percentileofscore(return_array, ret, kind="mean")
        ratings[ticker] = round(percentile, 1)

    logger.info(
        f"RS ratings computed for {len(ratings)} tickers (excluded {len(data) - len(ratings)} with <{required_days} days): "
        f"mean={np.mean(list(ratings.values())):.1f}, "
        f"median={np.median(list(ratings.values())):.1f}"
    )
    return ratings
